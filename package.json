{
  "name": "@inamul_hasan/vouch",
  "version": "1.3.0",
  "description": "Zero-selector, AI-powered browser automation. Write E2E tests in plain English — no CSS selectors, no XPaths. Uses computer vision (GPT-4o, Claude, Gemini, Ollama) + Playwright.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "vouch": "./dist/index.js"
  },
  "scripts": {
    "build": "bunx tsup",
    "dev": "bunx tsup --watch",
    "start": "node dist/index.js",
    "lint": "bunx tsc --noEmit"
  },
  "keywords": [
    "testing",
    "automation",
    "e2e",
    "end-to-end",
    "computer-vision",
    "ai",
    "ai-testing",
    "visual-testing",
    "vision-language-model",
    "playwright",
    "browser-automation",
    "qa",
    "natural-language",
    "no-code-testing",
    "self-healing",
    "zero-selector",
    "gpt-4o",
    "claude",
    "gemini",
    "ollama",
    "web-testing",
    "regression-testing"
  ],
  "author": {
    "name": "Inamul Hasan",
    "url": "https://github.com/HackX-IN"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HackX-IN/vouch.git"
  },
  "homepage": "https://github.com/HackX-IN/vouch#readme",
  "bugs": {
    "url": "https://github.com/HackX-IN/vouch/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/HackX-IN"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "USAGE.md",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@clack/prompts": "^1.6.0",
    "@google/generative-ai": "^0.21.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "figures": "^6.1.0",
    "openai": "^4.73.0",
    "ora": "^8.1.0",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
